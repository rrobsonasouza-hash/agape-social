rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function profile() { return firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data; }
    function active() { return request.auth != null && profile().status == 'ATIVO'; }
    function sameParish(paroquiaId) { return profile().role == 'admin_plataforma' || profile().paroquiaId == paroquiaId; }
    function canWrite() { return profile().role in ['admin_plataforma', 'admin_paroquia', 'coordenador', 'operador']; }
    match /paroquias/{paroquiaId}/{allPaths=**} {
      allow read: if active() && sameParish(paroquiaId);
      allow create, update: if active() && sameParish(paroquiaId) && canWrite()
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('(application/pdf|image/jpeg|image/png)');
      allow delete: if active() && sameParish(paroquiaId) && canWrite();
    }
  }
}
